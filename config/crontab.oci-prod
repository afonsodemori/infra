# minute - hour - day of month - month - day of week - command
37       3  *  *  0 cd /home/ops/infra/ && bin/certbot.sh renew >> /home/ops/data/crontab/certbot.log 2>&1
 7     */6  *  *  * cd /home/ops/infra/ && bin/postgres-backup.sh >> /home/ops/data/crontab/postgres-backup.log 2>&1
15,45    *  *  *  * cd /home/ops/crontab/afonsodev-resume-exporter/ && /bin/bash -c 'set -a; source .env; set +a; exec ./afonsodev-resume-exporter' >> /home/ops/data/crontab/afonsodev-resume-exporter.log 2>&1
